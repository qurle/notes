---
const { label = 'Click me' } = Astro.props
---

<div class="particle-burst">
  <canvas></canvas>
  <button class="button" type="button">{label}</button>
</div>

<style>
  .particle-burst {
    position: relative;
    display: flex;
    justify-content: center;
    padding: var(--space-2xl) 0;
  }

  canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
</style>

<script>
  import { getByClass, getByTag } from '@scripts/utils/getElements'

  for (const root of document.getElementsByClassName('particle-burst')) {
    const canvas = getByTag('canvas', root as HTMLElement)
    const button = getByClass('button', root as HTMLElement)
    const ctx = canvas.getContext('2d')!

    let particles: {
      x: number
      y: number
      vx: number
      vy: number
      life: number
      size: number
    }[] = []

    function resize() {
      const { width, height } = root.getBoundingClientRect()
      canvas.width = width * devicePixelRatio
      canvas.height = height * devicePixelRatio
    }

    function burst(x: number, y: number) {
      for (let i = 0; i < 48; i++) {
        const angle = (Math.PI * 2 * i) / 48 + Math.random() * 0.5
        const speed = 2 + Math.random() * 6
        particles.push({
          x,
          y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 1,
          size: 2 + Math.random() * 4,
        })
      }
    }

    function tick() {
      ctx.clearRect(0, 0, canvas.width, canvas.height)

      const color = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-main')
        .trim()

      particles = particles.filter((particle) => particle.life > 0)
      for (const particle of particles) {
        particle.x += particle.vx
        particle.y += particle.vy
        particle.vy += 0.15
        particle.life -= 0.02

        ctx.globalAlpha = Math.max(particle.life, 0)
        ctx.fillStyle = color
        ctx.beginPath()
        ctx.arc(particle.x, particle.y, particle.size, 0, Math.PI * 2)
        ctx.fill()
      }
      ctx.globalAlpha = 1

      requestAnimationFrame(tick)
    }

    resize()
    window.addEventListener('resize', resize)
    button.addEventListener('click', () => {
      const { width, height } = root.getBoundingClientRect()
      burst((width / 2) * devicePixelRatio, (height / 2) * devicePixelRatio)
    })
    tick()
  }
</script>
