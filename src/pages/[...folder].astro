---
import NoteLayout from '@layouts/NoteLayout.astro'
import { indexOfChar } from '@scripts/utils/indexOfChar'
import { unique } from '@scripts/utils/unique'

const rootPageName = 'home/'

export function getStaticPaths() {
  const folders = unique(
    Object.keys(
      import.meta.glob<Record<string, any>>(
        ['./*.{astro,html,mdx,md}', './**/*.{astro,html,mdx,md}'],
        { eager: true, query: '?url' },
      ),
    )
      // Only folders
      .filter((path) => path.split('/').length > 2)
      // Remove files from routes
      .map((path) => path.replace(/^\.\/|\/[^\/]*$/g, ''))
      // Add each folder on the way
      .flatMap((folder) =>
        folder
          .split('/')
          .map((_, i, arr) => arr.slice(0, i + 1).join('/') + '/'),
      ),
  )

  console.log(folders)

  return [
    ...folders.map((folder) => ({ params: { folder } })),
    { params: { folder: '' } },
  ]
}

const { folder } = Astro.params
const currentPath = folder ? `./${folder}/` : './'
const currentFolder = folder?.split('/').at(-1)

const title = folder ? currentFolder + '/' : rootPageName

const allFiles = Object.keys(
  import.meta.glob<Record<string, any>>(
    ['./*.{astro,html,mdx,md}', './**/*.{astro,html,mdx,md}'],
    { eager: true, query: '?url' },
  ),
)

const contents = allFiles.filter((path) => path.startsWith(currentPath))

const nextLevelFolders = new RegExp(
  `^${currentPath.replace(/\./g, '\\.')}([^/]+/)`,
)

const folders = unique(
  contents
    .filter((path) => path.replace(currentPath, '').split('/').length > 1)
    .map((path) => path.match(nextLevelFolders)?.[1])
    .filter(Boolean),
)

const pages = contents
  .filter((path) => path.replace(currentPath, '').split('/').length === 1)
  .map((path) => ({
    href: path.replace(/^\.(.+)\.[^.]+$/, '$1'),
    name: path.split('/').at(-1),
  }))
console.log('currentFolder')
console.log(currentFolder)
console.log('currentPath')
console.log(currentPath)
console.log('contents')
console.log(contents)
console.log('folders')
console.log(folders)
console.log('pages')
console.log(pages)
---

<NoteLayout {title}>
  <h1>{title}</h1>
  <ul class="entries">
    {
      folders.map((path) => (
        <li class="folder">
          <a href={path}>{path}</a>
        </li>
      ))
    }
    {folders.length > 0 && pages.length > 0 && <hr />}
    {
      pages.map(({ href, name }) => (
        <li>
          <a href={href}>{name}</a>
        </li>
      ))
    }
  </ul>
</NoteLayout>
<script>
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.entries a'),
  )

  const RESTORE_KEY = `focusRestore:${window.location.pathname}`
  let keyboardUsed = false

  // Restore focus when returning from a subfolder entered via keyboard
  const savedHref = sessionStorage.getItem(RESTORE_KEY)
  if (savedHref) {
    sessionStorage.removeItem(RESTORE_KEY)
    links.find((l) => l.getAttribute('href') === savedHref)?.focus()
  }

  // Save focus target when navigating to any entry via keyboard
  links.forEach((link) => {
    link.addEventListener('click', () => {
      if (keyboardUsed) {
        sessionStorage.setItem(RESTORE_KEY, link.getAttribute('href')!)
      }
    })
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelector<HTMLAnchorElement>('.back')?.click()
      return
    }
    if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return
    e.preventDefault()
    keyboardUsed = true

    const idx = links.indexOf(document.activeElement as HTMLAnchorElement)
    const next =
      e.key === 'ArrowDown'
        ? idx === -1
          ? 0
          : (idx + 1) % links.length
        : idx === -1
          ? links.length - 1
          : (idx - 1 + links.length) % links.length
    links[next].focus()
  })
</script>
